{
  "info": {
    "name": "MegaSuper - Producto CRUD",
    "_postman_id": "4f7cab21-ec0b-4f28-bf5a-f1c9406ae2f7",
    "description": "Coleccion para validar CRUD completo con un unico script de tests a nivel coleccion.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "productoId",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = pm.info.requestName;",
          "let body = null;",
          "",
          "try {",
          "  body = pm.response.json();",
          "} catch (error) {",
          "  body = null;",
          "}",
          "",
          "const ensureStatus = (expectedStatus) => {",
          "  pm.test(`Status ${expectedStatus}`, function () {",
          "    pm.response.to.have.status(expectedStatus);",
          "  });",
          "};",
          "",
          "const ensureTimestamp = (target) => {",
          "  pm.expect(target).to.have.property('timestamp');",
          "  pm.expect(target.timestamp).to.be.a('string').and.not.empty;",
          "};",
          "",
          "const ensureBodySuccess = () => {",
          "  pm.test('Body success valido', function () {",
          "    pm.expect(body).to.be.an('object');",
          "    pm.expect(body.status).to.eql('success');",
          "    pm.expect(body).to.have.property('data');",
          "  });",
          "};",
          "",
          "const ensureBodyFail = () => {",
          "  pm.test('Body fail valido', function () {",
          "    pm.expect(body).to.be.an('object');",
          "    pm.expect(body.status).to.eql('fail');",
          "    pm.expect(body.message).to.be.a('string').and.not.empty;",
          "    ensureTimestamp(body);",
          "  });",
          "};",
          "",
          "const ensurePaginacion = (expectedPage, expectedLimit) => {",
          "  pm.test('Paginacion valida', function () {",
          "    pm.expect(body).to.have.property('paginacion');",
          "    pm.expect(body.paginacion).to.be.an('object');",
          "    pm.expect(body.paginacion.numeroPagina).to.eql(expectedPage);",
          "    pm.expect(body.paginacion.limitePorPagina).to.eql(expectedLimit);",
          "    pm.expect(body.paginacion.totalPaginas).to.be.a('number');",
          "    pm.expect(body.paginacion.totalProductos).to.be.a('number');",
          "    pm.expect(body.paginacion.totalPaginas).to.be.at.least(0);",
          "    pm.expect(body.paginacion.totalProductos).to.be.at.least(0);",
          "  });",
          "};",
          "",
          "switch (requestName) {",
          "  case '1. GET /productos - listar':",
          "    ensureStatus(200);",
          "    ensureBodySuccess();",
          "    pm.test('data es array', function () {",
          "      pm.expect(Array.isArray(body.data)).to.eql(true);",
          "    });",
          "    ensurePaginacion(1, 10);",
          "    pm.test('consistencia totalProductos >= data.length', function () {",
          "      pm.expect(body.paginacion.totalProductos).to.be.at.least(body.data.length);",
          "    });",
          "    console.info('OK listar productos -> cantidad:', body.data.length);",
          "    break;",
          "",
          "  case '2. POST /productos - crear':",
          "    ensureStatus(201);",
          "    ensureBodySuccess();",
          "    pm.test('crea producto con id', function () {",
          "      pm.expect(body.data).to.have.property('id');",
          "    });",
          "    pm.collectionVariables.set('productoId', body.data.id);",
          "    pm.collectionVariables.set('productoNombre', body.data.nombre);",
          "    console.info('OK crear producto -> id:', body.data.id);",
          "    break;",
          "",
          "  case '3. POST /productos - nombre duplicado':",
          "    ensureStatus(409);",
          "    ensureBodyFail();",
          "    pm.test('mensaje de duplicado', function () {",
          "      pm.expect(body.message.toLowerCase()).to.include('existe');",
          "    });",
          "    console.info('OK validacion duplicado ->', body.message);",
          "    break;",
          "",
          "  case '4. GET /productos/:id - obtener por id':",
          "    ensureStatus(200);",
          "    ensureBodySuccess();",
          "    pm.test('id coincide con variable de coleccion', function () {",
          "      pm.expect(String(body.data.id)).to.eql(String(pm.collectionVariables.get('productoId')));",
          "    });",
          "    console.info('OK obtener por id ->', body.data);",
          "    break;",
          "",
          "  case '5. PUT /productos/:id - actualizar':",
          "    ensureStatus(200);",
          "    ensureBodySuccess();",
          "    pm.test('actualiza nombre y precio', function () {",
          "      pm.expect(body.data.nombre).to.eql('Yerba Tradicional Premium');",
          "      pm.expect(body.data.precio).to.eql(4000);",
          "    });",
          "    console.info('OK actualizar producto');",
          "    break;",
          "",
          "  case '6. GET /productos/abc - id invalido':",
          "    ensureStatus(400);",
          "    ensureBodyFail();",
          "    pm.test('mensaje menciona id', function () {",
          "      pm.expect(body.message.toLowerCase()).to.include('id');",
          "    });",
          "    console.info('OK validacion id invalido ->', body.message);",
          "    break;",
          "",
          "  case '6.1 GET /productos?page=1&limit=1 - paginado':",
          "    ensureStatus(200);",
          "    ensureBodySuccess();",
          "    pm.test('data es array', function () {",
          "      pm.expect(Array.isArray(body.data)).to.eql(true);",
          "      pm.expect(body.data.length).to.be.at.most(1);",
          "    });",
          "    ensurePaginacion(1, 1);",
          "    pm.test('si hay productos totalPaginas >= 1', function () {",
          "      if (body.paginacion.totalProductos > 0) {",
          "        pm.expect(body.paginacion.totalPaginas).to.be.at.least(1);",
          "      } else {",
          "        pm.expect(body.paginacion.totalPaginas).to.eql(0);",
          "      }",
          "    });",
          "    console.info('OK paginado ->', body.paginacion);",
          "    break;",
          "",
          "  case '6.2 GET /productos?page=0&limit=1 - paginacion invalida':",
          "    ensureStatus(400);",
          "    ensureBodyFail();",
          "    pm.test('mensaje menciona page', function () {",
          "      pm.expect(body.message.toLowerCase()).to.include('page');",
          "    });",
          "    console.info('OK validacion paginacion invalida ->', body.message);",
          "    break;",
          "",
          "  case '7. DELETE /productos/:id - eliminar':",
          "    ensureStatus(200);",
          "    ensureBodySuccess();",
          "    pm.test('elimina el mismo id creado', function () {",
          "      pm.expect(String(body.data.id)).to.eql(String(pm.collectionVariables.get('productoId')));",
          "    });",
          "    console.info('OK eliminar producto -> id:', body.data.id);",
          "    break;",
          "",
          "  case '8. GET /productos/:id - no encontrado':",
          "    ensureStatus(404);",
          "    ensureBodyFail();",
          "    pm.test('mensaje de no encontrado', function () {",
          "      pm.expect(body.message.toLowerCase()).to.include('no encontrado');",
          "    });",
          "    console.info('OK no encontrado post delete ->', body.message);",
          "    break;",
          "",
          "  default:",
          "    pm.test('Request no contemplado por el script general', function () {",
          "      pm.expect.fail(`No hay validaciones definidas para: ${requestName}`);",
          "    });",
          "}",
          ""
        ]
      }
    }
  ],
